{
  "name": "promptseal-dashboard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Operator-facing tree view + URL-driven verifier for PromptSeal evidence packs (v0.2). Vanilla /verifier remains the trustless fallback.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:single": "SELF_CONTAINED=1 tsc -b && SELF_CONTAINED=1 vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.27.0",
    "@noble/ed25519": "2.1.0",
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.3",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3",
    "vite": "5.4.10",
    "tailwindcss": "3.4.14",
    "postcss": "8.4.47",
    "autoprefixer": "10.4.20",
    "vite-plugin-singlefile": "2.0.3"
  }
}
